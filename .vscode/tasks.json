{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build all",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--config",
        "${input:buildType}"
      ],
      "dependsOn": [
        "cmake: configure"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "cmake: build kernel",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "mtcad_kernel",
        "--config",
        "${input:buildType}"
      ],
      "dependsOn": [
        "cmake: configure"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build gui",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "mtcad_gui",
        "--config",
        "${input:buildType}"
      ],
      "dependsOn": [
        "cmake: configure"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Inno: build installer",
      "type": "shell",
      "command": "iscc",
      "args": [
        "${workspaceFolder}/installer/MTCAD.iss"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "DEB: build package",
      "type": "shell",
      "command": "cpack",
      "args": [
        "-G",
        "DEB"
      ],
      "options": {
        "cwd": "${workspaceFolder}/build"
      },
      "dependsOn": [
        "cmake: build all"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "RPM: build package",
      "type": "shell",
      "command": "cpack",
      "args": [
        "-G",
        "RPM"
      ],
      "options": {
        "cwd": "${workspaceFolder}/build"
      },
      "dependsOn": [
        "cmake: build all"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: make AppDir",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--install",
        "build",
        "--prefix",
        "/usr"
      ],
      "options": {
        "env": {
          "DESTDIR": "${workspaceFolder}/AppDir"
        }
      },
      "dependsOn": [
        "cmake: build all"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build appdir",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "appdir",
        "--config",
        "${input:buildType}"
      ],
      "dependsOn": [
        "cmake: make AppDir"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "AppImage: build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "appimage",
        "--config",
        "${input:buildType}"
      ],
      "dependsOn": [
        "cmake: build appdir"
      ],
      "group": "build",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "buildType",
      "type": "pickString",
      "description": "CMake build configuration",
      "options": [
        "Debug",
        "Release"
      ],
      "default": "Debug"
    }
  ]
}
